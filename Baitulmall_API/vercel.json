{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1",
            "memory": 512
        },
        "api/health.php": {
            "runtime": "vercel-php@0.7.1",
            "memory": 256
        },
        "api/deploy.php": {
            "runtime": "vercel-php@0.7.1",
            "memory": 512
        },
        "api/list-users.php": {
            "runtime": "vercel-php@0.7.1",
            "memory": 256
        }
    },
    "rewrites": [
        {
            "source": "/deploy-native",
            "destination": "api/deploy.php"
        },
        {
            "source": "/list-users",
            "destination": "api/list-users.php"
        },
        {
            "source": "/health",
            "destination": "api/health.php"
        },
        {
            "source": "/(.*)",
            "destination": "api/index.php"
        }
    ]
}
